# FixYourPrompts Frontend Environment Variables
# Copy this file to .env.local and customize the values for your environment

# ===================
# Application Settings
# ===================

# Application environment: development, staging, production
VITE_APP_ENV=development

# Application name and version
VITE_APP_NAME=FixYourPrompts
VITE_APP_VERSION=1.0.0

# Application URL (used for absolute URLs, sharing, etc.)
VITE_APP_URL=http://localhost:5173

# ===================
# API Configuration
# ===================

# API base URL
VITE_API_BASE_URL=http://localhost:8080

# API version
VITE_API_VERSION=v1

# API request timeout in milliseconds (1000-60000)
VITE_API_TIMEOUT=10000

# Enable API request/response logging (true/false)
VITE_API_LOGGING=true

# API retry configuration
VITE_API_RETRY_MAX_ATTEMPTS=3
VITE_API_RETRY_BASE_DELAY=1000
VITE_API_RETRY_MAX_DELAY=10000

# ===================
# API Key Management
# ===================

# Default user ID for API key management (development only)
VITE_DEFAULT_USER_ID=default-user

# API key validation timeout in milliseconds
VITE_API_KEY_VALIDATION_TIMEOUT=5000

# ===================
# Feature Flags
# ===================

# Enable advanced prompt analytics (true/false)
VITE_FEATURE_ANALYTICS=false

# Enable user feedback collection (true/false)
VITE_FEATURE_FEEDBACK=true

# Enable experimental AI features (true/false)
VITE_FEATURE_EXPERIMENTAL=true

# Enable real-time collaboration (true/false)
VITE_FEATURE_COLLABORATION=false

# Enable prompt sharing functionality (true/false)
VITE_FEATURE_SHARING=false

# Enable dark mode toggle (true/false)
VITE_FEATURE_DARK_MODE=true

# ===================
# Debug Settings
# ===================

# Enable debug mode (true/false)
VITE_DEBUG_ENABLED=true

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=debug

# Enable React DevTools integration (true/false)
VITE_DEBUG_REACT_DEVTOOLS=true

# Enable Redux DevTools (true/false)
VITE_DEBUG_REDUX_DEVTOOLS=true

# Enable performance monitoring (true/false)
VITE_DEBUG_PERFORMANCE=true

# Enable error boundary reporting (true/false)
VITE_DEBUG_ERROR_REPORTING=false

# ===================
# Build Information
# ===================

# Build timestamp (auto-generated if not provided)
VITE_BUILD_TIME=

# Git commit hash (auto-generated if not provided)
VITE_GIT_COMMIT_HASH=

# Git branch name (auto-generated if not provided)
VITE_GIT_BRANCH_NAME=

# ===================
# Build Optimizations
# ===================

# Analyze bundle size after build (true/false)
ANALYZE=false

# Use CDN for external dependencies (true/false)
USE_CDN=false

# ===================
# Environment Examples
# ===================

# Development Environment:
# VITE_APP_ENV=development
# VITE_APP_URL=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:3000
# VITE_FEATURE_EXPERIMENTAL=true
# VITE_DEBUG_ENABLED=true

# Staging Environment:
# VITE_APP_ENV=staging
# VITE_APP_URL=https://staging.fixyourprompts.com
# VITE_API_BASE_URL=https://staging-api.fixyourprompts.com
# VITE_FEATURE_EXPERIMENTAL=false
# VITE_DEBUG_ENABLED=false

# Production Environment:
# VITE_APP_ENV=production
# VITE_APP_URL=https://fixyourprompts.com
# VITE_API_BASE_URL=https://api.fixyourprompts.com
# VITE_FEATURE_ANALYTICS=true
# VITE_FEATURE_SHARING=true
# VITE_DEBUG_ENABLED=false
# VITE_DEBUG_ERROR_REPORTING=true