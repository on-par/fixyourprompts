{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:only": "vite build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:production": "NODE_ENV=production npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:clear": "vitest --clear-cache",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "./scripts/ci-local.sh",
    "ci:quick": "./scripts/ci-local.sh true",
    "bundle:analyze": "npx vite-bundle-analyzer dist/js",
    "bundle:visualize": "rollup-plugin-visualizer --open --file dist/bundle-analysis.html",
    "bundle:stats": "node scripts/bundle-stats.js",
    "bundle:size": "node scripts/bundle-size-check.js",
    "bundle:monitor": "node scripts/bundle-monitor.js",
    "bundle:report": "npm run build:stats && npm run bundle:analyze",
    "bundle:check": "bundlesize",
    "performance:budget": "node scripts/performance-budget.js",
    "size:check": "bundlesize",
    "size:limit": "size-limit",
    "security:audit": "npm audit --audit-level=moderate",
    "clean": "rm -rf dist node_modules/.vite coverage test-results playwright-report",
    "pretest": "npm run typecheck",
    "prebuild": "npm run typecheck && npm run lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:test": "test-storybook",
    "chromatic": "chromatic --exit-zero-on-changes --build-script-name=build-storybook",
    "chromatic:ci": "chromatic --exit-zero-on-changes --only-changed"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.2",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.57.0",
    "@size-limit/preset-app": "^11.2.0",
    "@storybook/addon-a11y": "^9.1.15",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-docs": "^9.1.15",
    "@storybook/addon-onboarding": "^9.1.15",
    "@storybook/addon-vitest": "^9.1.15",
    "@storybook/react-vite": "^9.1.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.13",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "4.0.15",
    "@vitest/coverage-v8": "4.0.15",
    "@vitest/ui": "^4.0.15",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "bundlesize": "^0.18.2",
    "chromatic": "^13.3.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-storybook": "^9.1.8",
    "globals": "^16.5.0",
    "gzip-size": "^7.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "size-limit": "^11.2.0",
    "storybook": "^9.1.13",
    "terser": "^5.44.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.2.2",
    "vite-bundle-analyzer": "^0.10.6",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.15"
  },
  "bundlesize": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "250 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/assets/*.css",
      "maxSize": "50 kB",
      "compression": "gzip"
    }
  ],
  "size-limit": [
    {
      "name": "Main Bundle",
      "path": "dist/assets/index-*.js",
      "limit": "250 kB",
      "gzip": true
    },
    {
      "name": "CSS Bundle",
      "path": "dist/assets/index-*.css",
      "limit": "50 kB",
      "gzip": true
    }
  ]
}
