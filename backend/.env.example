# Backend Environment Configuration
# Copy this file to .env and update the values

# Encryption key for API key storage (required in production)
# Generate a secure 32-character key using: openssl rand -hex 32
ENCRYPTION_KEY=your-secure-encryption-key-here-32-chars

# Server configuration
PORT=8080
HOST=0.0.0.0

# Database configuration
DATABASE_URL=fixyourprompts.db

# Node environment
NODE_ENV=development

# Logging level
LOG_LEVEL=info

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# API Key validation timeout (milliseconds)
API_KEY_VALIDATION_TIMEOUT=5000